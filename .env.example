APP_NAME=Dwellow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Comma-separated emails allowed into the Filament admin panel (devs/founders only).
ADMIN_EMAILS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Defaults to true in production (HTTPS-only cookies). Leave unset for local HTTP.
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_SUPPORT_ADDRESS="${MAIL_FROM_ADDRESS}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# AI provider for screening Scores (config/ai.php). Defaults to Ollama so local
# development never hits a paid endpoint; production sets AI_PROVIDER=anthropic.
# AI_PROVIDER=ollama

# Ollama (local). The Sail container reaches host-machine Ollama via
# host.docker.internal — NOT localhost. Pull the model first: `ollama pull <model>`.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:14b-instruct

# Anthropic (production). Leave the key blank locally; never commit a real secret.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

VITE_APP_NAME="${APP_NAME}"
